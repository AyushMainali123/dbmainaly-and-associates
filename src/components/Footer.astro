---
const currentYear = new Date().getFullYear();
---

<footer class="w-full border-t border-outline-variant/15 bg-surface-container dark:bg-[#191c1e] font-sans text-sm leading-relaxed mt-auto">
  <div class="grid grid-cols-1 md:grid-cols-4 gap-12 max-w-[1440px] mx-auto px-16 py-20">
    <div class="space-y-6">
      <div class="text-lg font-bold text-primary dark:text-white">DB Mainaly & Associates</div>
      <p class="text-on-surface-variant dark:text-outline-variant max-w-xs">
        Leading chartered accountancy firm providing elite audit, tax, and legal advisory across Nepal and South Asia.
      </p>
      <div class="flex gap-4">
        <span class="material-symbols-outlined text-primary">alternate_email</span>
        <span class="material-symbols-outlined text-primary">call</span>
        <span class="material-symbols-outlined text-primary">location_on</span>
      </div>
    </div>
    <div class="space-y-6">
      <h4 class="font-bold text-primary dark:text-white tracking-wide uppercase text-xs">Services</h4>
      <ul class="space-y-4">
        <li><a class="text-on-surface-variant dark:text-outline-variant hover:text-primary transition-all" href="/services">Tax Advisory</a></li>
        <li><a class="text-on-surface-variant dark:text-outline-variant hover:text-primary transition-all" href="/services">Audit & Assurance</a></li>
        <li><a class="text-on-surface-variant dark:text-outline-variant hover:text-primary transition-all" href="/services">Corporate Law</a></li>
        <li><a class="text-on-surface-variant dark:text-outline-variant hover:text-primary transition-all" href="/services">Financial Consulting</a></li>
      </ul>
    </div>
    <div class="space-y-6">
      <h4 class="font-bold text-primary dark:text-white tracking-wide uppercase text-xs">Resources</h4>
      <ul class="space-y-4">
        <li><a class="text-on-surface-variant dark:text-outline-variant hover:text-primary transition-all" href="/resources">Privacy Policy</a></li>
        <li><a class="text-on-surface-variant dark:text-outline-variant hover:text-primary transition-all" href="/resources">Compliance</a></li>
        <li><a class="text-on-surface-variant dark:text-outline-variant hover:text-primary transition-all" href="/resources">Client Portal</a></li>
        <li><a class="text-on-surface-variant dark:text-outline-variant hover:text-primary transition-all" href="/resources">Annual Reports</a></li>
      </ul>
    </div>
    <div class="space-y-6">
      <h4 class="font-bold text-primary dark:text-white tracking-wide uppercase text-xs">Headquarters</h4>
      <p class="text-on-surface-variant dark:text-outline-variant">
        Lalitpur-03, Kathmandu, Nepal<br/>
        Professional Building, 4th Floor
      </p>
      <div class="pt-4 border-t border-outline-variant/20">
        <p class="text-on-surface-variant font-medium">Licensed by ICAN Nepal</p>
        <p class="text-on-surface-variant/60 text-[10px] mt-1">Certificate #0045/FY80</p>
      </div>
    </div>
  </div>
  <div class="max-w-[1440px] mx-auto px-16 pb-12">
    <div class="pt-8 border-t border-outline-variant/15 flex flex-col md:flex-row justify-between items-center gap-6 text-on-surface-variant/60 text-xs">
      <p>© {currentYear} DB Mainaly & Associates. Member of ICAN.</p>
      <div class="flex gap-8">
        <a class="hover:text-primary" href="#">LinkedIn</a>
        <a class="hover:text-primary" href="/blog">Financial Intelligence</a>
        <a class="hover:text-primary" href="#">Careers</a>
      </div>
    </div>
  </div>
</footer>
