---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const blogPosts = await getCollection('blog');
const featuredPost = blogPosts.find(post => post.data.featured) || blogPosts[0];
const regularPosts = blogPosts.filter(post => post.id !== featuredPost.id);
---

<BaseLayout title="Insights & Analysis | DB Mainaly & Associates">
  <Header />

  <main class="max-w-[1440px] mx-auto px-12 lg:pl-[4rem] lg:pr-[5.5rem] py-20">
    <header class="mb-24">
      <div class="max-w-3xl">
        <span class="label-md text-primary font-bold tracking-[0.1rem] uppercase block mb-4">Firm Insights</span>
        <h1 class="text-6xl md:text-7xl font-bold tracking-tight text-on-surface leading-tight mb-8">
          Insights & Analysis
        </h1>
        <p class="text-xl text-on-surface-variant leading-relaxed font-medium">
          Critical updates and strategic perspectives on Nepal's evolving financial, regulatory, and corporate landscape from our senior advisors.
        </p>
      </div>
    </header>

    <!-- Featured Article -->
    {featuredPost && (
      <section class="mb-24">
        <div class="relative group overflow-hidden rounded-xl bg-surface-container-lowest shadow-[0_20px_40px_rgba(0,35,111,0.04)]">
          <div class="flex flex-col lg:flex-row">
            <div class="lg:w-7/12 overflow-hidden h-[450px]">
              <img src={featuredPost.data.image} alt={featuredPost.data.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
            </div>
            <div class="lg:w-5/12 p-12 flex flex-col justify-center">
              <span class="text-primary font-bold text-sm tracking-widest mb-4 uppercase">{featuredPost.data.category} • {featuredPost.data.readTime}</span>
              <h2 class="text-3xl font-bold text-on-surface mb-6 leading-snug hover:text-primary transition-colors">
                <a href={`/blog/${featuredPost.id}`}>{featuredPost.data.title}</a>
              </h2>
              <p class="text-on-surface-variant mb-8 line-clamp-3">
                {featuredPost.data.excerpt}
              </p>
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center">
                  <span class="material-symbols-outlined text-primary">person</span>
                </div>
                <div>
                  <p class="text-sm font-bold text-on-surface">By {featuredPost.data.author}</p>
                  <p class="text-xs text-on-surface-variant">{featuredPost.data.authorRole}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    )}

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
      <div class="lg:col-span-8">
        <!-- Category Filter -->
        <div class="flex flex-wrap gap-4 mb-12">
          <button class="px-6 py-2 rounded-full bg-primary text-on-primary font-bold text-sm transition-all">All</button>
          <button class="px-6 py-2 rounded-full bg-surface-container text-on-surface-variant font-bold text-sm hover:bg-surface-container-high transition-all">Taxation</button>
          <button class="px-6 py-2 rounded-full bg-surface-container text-on-surface-variant font-bold text-sm hover:bg-surface-container-high transition-all">Audit</button>
          <button class="px-6 py-2 rounded-full bg-surface-container text-on-surface-variant font-bold text-sm hover:bg-surface-container-high transition-all">Regulatory</button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-16">
          {regularPosts.map(post => (
            <article class="group">
              <div class="aspect-video mb-6 overflow-hidden rounded-lg bg-surface-container">
                <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110">
              </div>
              <span class="text-xs font-bold text-primary tracking-widest uppercase mb-3 block">{post.data.category}</span>
              <h3 class="text-2xl font-bold text-on-surface mb-4 leading-tight group-hover:text-primary transition-colors">
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
              </h3>
              <p class="text-on-surface-variant mb-6 text-sm leading-relaxed line-clamp-2">
                {post.data.excerpt}
              </p>
              <div class="flex items-center justify-between">
                <span class="text-xs text-outline font-medium">{post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
                <a class="text-primary font-bold text-sm flex items-center gap-2" href={`/blog/${post.id}`}>
                  Read More <span class="material-symbols-outlined text-sm">arrow_forward</span>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>

      <aside class="lg:col-span-4 space-y-12">
        <div class="bg-primary-fixed p-10 rounded-xl relative overflow-hidden">
          <div class="relative z-10">
            <h4 class="text-2xl font-bold text-on-primary-fixed mb-4">The Ledger Monthly</h4>
            <p class="text-on-primary-fixed-variant mb-8 text-sm leading-relaxed">
              Get exclusive regulatory summaries and fiscal updates delivered directly to your inbox.
            </p>
            <form class="space-y-4">
              <input class="w-full bg-surface-container-lowest border-none rounded-lg px-4 py-3 text-sm focus:ring-2 focus:ring-primary transition-all" placeholder="Corporate Email Address" type="email">
              <button class="w-full bg-primary text-on-primary font-bold py-3 rounded-lg hover:bg-primary-container transition-all">
                Subscribe Now
              </button>
            </form>
          </div>
        </div>

        <div class="p-2">
          <h4 class="text-lg font-bold text-on-surface mb-6 flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">trending_up</span> Trending Analysis
          </h4>
          <ul class="space-y-6">
            <li class="border-b border-outline-variant/15 pb-4">
              <a class="text-sm font-semibold text-on-surface hover:text-primary transition-colors" href="#">SEBON's New IPO Pricing Guidelines: What You Need to Know</a>
            </li>
            <li class="border-b border-outline-variant/15 pb-4">
              <a class="text-sm font-semibold text-on-surface hover:text-primary transition-colors" href="#">Double Taxation Avoidance Agreement (DTAA) with China</a>
            </li>
          </ul>
        </div>
      </aside>
    </div>
  </main>

  <Footer />
</BaseLayout>
