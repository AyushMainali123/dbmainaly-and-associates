---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import { getCollection } from 'astro:content';

const services = await getCollection('services');
const featuredBlogPosts = await getCollection('blog', ({ data }) => data.featured);
---

<BaseLayout>
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="relative bg-gradient-to-br from-primary to-primary-container overflow-hidden min-h-[800px] flex items-center">
      <div class="absolute inset-0 opacity-10">
        <div class="absolute top-0 right-0 w-1/2 h-full bg-[url('https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=2070&auto=format&fit=crop')] bg-cover bg-center mix-blend-overlay"></div>
      </div>
      <div class="max-w-[1440px] mx-auto px-12 w-full grid grid-cols-1 md:grid-cols-12 gap-8 relative z-10">
        <div class="md:col-span-8">
          <div class="inline-flex items-center gap-2 mb-6 px-3 py-1 bg-surface-container-lowest/10 rounded-full border border-white/10">
            <span class="w-2 h-2 rounded-full bg-tertiary-fixed-dim"></span>
            <span class="text-white text-[10px] tracking-[0.2em] font-bold uppercase">Member of ICAN Nepal</span>
          </div>
          <h1 class="text-white text-5xl md:text-7xl font-bold tracking-tight leading-[1.1] mb-8">
            Professional Financial <br/>Excellence.
          </h1>
          <p class="text-primary-fixed text-xl max-w-xl leading-relaxed mb-10 opacity-90">
            Navigating the complexities of Nepalese corporate law and global financial standards with architectural precision and unwavering integrity.
          </p>
          <div class="flex flex-wrap gap-4">
            <Button href="/services" variant="surface" size="lg">Explore Advisory</Button>
            <Button href="/about" variant="outline" size="lg">Our Portfolio</Button>
          </div>
        </div>
      </div>
    </section>

    <!-- Compliance Badge Section -->
    <div class="bg-surface-container-low py-12">
      <div class="max-w-[1440px] mx-auto px-12 flex flex-col md:flex-row items-center justify-between gap-8 opacity-80">
        <div class="flex items-center gap-6">
          <div class="w-16 h-16 bg-surface-container-lowest rounded-full flex items-center justify-center border border-outline-variant/20 shadow-sm">
            <span class="material-symbols-outlined text-primary text-3xl">verified</span>
          </div>
          <div>
            <p class="text-[10px] text-primary font-bold tracking-widest uppercase mb-1">Regulatory Standard</p>
            <p class="text-on-surface font-semibold">Institute of Chartered Accountants of Nepal (ICAN) Licensed</p>
          </div>
        </div>
        <div class="h-px w-24 bg-outline-variant/30 hidden md:block"></div>
        <div class="flex gap-12 grayscale opacity-60">
          <span class="text-lg font-extrabold tracking-tighter">FIN-COMPLY</span>
          <span class="text-lg font-extrabold tracking-tighter">TAX-NEPAL</span>
          <span class="text-lg font-extrabold tracking-tighter">AUDIT-CORP</span>
        </div>
      </div>
    </div>

    <!-- Strategic Financial Services: Bento Grid Layout -->
    <section class="py-32 bg-surface">
      <div class="max-w-[1440px] mx-auto px-12">
        <div class="mb-20 flex flex-col md:flex-row md:items-end justify-between gap-6">
          <div>
            <p class="text-primary font-bold tracking-[0.15em] uppercase text-xs mb-4">Core Competencies</p>
            <h2 class="text-4xl md:text-5xl font-bold tracking-tight text-on-surface">Strategic Financial Services</h2>
          </div>
          <p class="text-on-surface-variant max-w-md text-lg leading-relaxed">
            A multidisciplinary approach to fiscal health, combining local expertise with international standards.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
          {services.map((service, index) => (
            <div class={`${index === 0 ? "md:col-span-8" : index === 1 ? "md:col-span-4 bg-primary text-white" : "md:col-span-6"} group relative overflow-hidden p-12 rounded-xl transition-all duration-500 hover:shadow-xl ${index === 0 ? "bg-surface-container-lowest border border-outline-variant/10" : index === 1 ? "" : index === 2 ? "bg-surface-container-high" : "bg-surface-container-lowest border border-outline-variant/10"}`}>
              <div class="relative z-10 h-full flex flex-col justify-between">
                <div>
                  <span class={`material-symbols-outlined text-4xl mb-8 ${index === 1 ? "text-tertiary-fixed-dim" : "text-primary"}`}>{service.data.icon}</span>
                  <h3 class={`text-3xl font-bold mb-4 ${index === 1 ? "text-white" : "text-on-surface"}`}>{service.data.title}</h3>
                  <p class={`text-lg leading-relaxed ${index === 1 ? "text-primary-fixed/80" : "text-on-surface-variant"} max-w-lg`}>
                    {service.data.description}
                  </p>
                </div>
                <div class="mt-12">
                  {index === 0 && (
                    <ul class="grid grid-cols-1 md:grid-cols-2 gap-4 text-on-surface font-medium mb-10">
                      {service.data.features.map(feature => (
                        <li class="flex items-center gap-3"><span class="w-1.5 h-1.5 rounded-full bg-primary"></span> {feature}</li>
                      ))}
                    </ul>
                  )}
                  <a href={`/services#${service.id}`} class={`inline-flex items-center gap-2 font-bold hover:gap-4 transition-all ${index === 1 ? "text-tertiary-fixed-dim" : "text-primary"}`}>
                    {index === 1 ? "Consult Expert" : "View Practice Area"} <span class="material-symbols-outlined">arrow_right_alt</span>
                  </a>
                </div>
              </div>
              <div class={`absolute -right-20 -bottom-20 opacity-[0.03] scale-150 pointer-events-none ${index === 1 ? "text-white" : "text-primary"}`}>
                <span class="material-symbols-outlined text-[20rem]">{service.data.icon}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Our Impact Section -->
    <section class="py-32 bg-surface-container-lowest">
      <div class="max-w-[1440px] mx-auto px-12 grid grid-cols-1 md:grid-cols-2 gap-24 items-center">
        <div class="relative">
          <div class="absolute left-0 top-0 w-1 h-full bg-surface-container-high overflow-hidden">
            <div class="absolute bottom-0 left-0 w-full h-3/4 bg-primary transition-all duration-1000"></div>
          </div>
          <div class="pl-12 py-8">
            <p class="text-primary font-bold tracking-widest uppercase text-xs mb-6">Our Trajectory</p>
            <h2 class="text-5xl font-bold tracking-tight mb-8 leading-[1.1]">Decades of <br/>Fiscal Authority.</h2>
            <p class="text-on-surface-variant text-xl leading-relaxed mb-12">
              Since our inception, we have been the standard-bearer for financial integrity in Nepal, guiding organizations from startup to public listing.
            </p>
            <div class="grid grid-cols-2 gap-12">
              <div>
                <h4 class="text-4xl font-extrabold text-primary mb-2">15+</h4>
                <p class="text-on-surface font-bold text-sm tracking-wide uppercase">Years Excellence</p>
              </div>
              <div>
                <h4 class="text-4xl font-extrabold text-primary mb-2">500+</h4>
                <p class="text-on-surface font-bold text-sm tracking-wide uppercase">Active Clients</p>
              </div>
              <div>
                <h4 class="text-4xl font-extrabold text-primary mb-2">1.2B</h4>
                <p class="text-on-surface font-bold text-sm tracking-wide uppercase">Capital Managed</p>
              </div>
              <div>
                <h4 class="text-4xl font-extrabold text-primary mb-2">100%</h4>
                <p class="text-on-surface font-bold text-sm tracking-wide uppercase">Compliance Rate</p>
              </div>
            </div>
          </div>
        </div>
        <div class="relative aspect-square">
          <div class="absolute inset-0 bg-primary-container rounded-2xl transform rotate-3 scale-95 opacity-10"></div>
          <div class="relative h-full rounded-2xl overflow-hidden shadow-2xl">
            <img class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCmJZluKrtPXRzVVWeH0StgnmQD3eDHXqN62gi69SbQho1mElHKl9-_mKuBgYSX6eteGnThtwEY33b5tBljxRhOP2MtHb774DNZncc4GBHm8Z53M_RLqHuyrnVVhE74lM6x7XamD6Mmh6lYB4rKKKD5y9OOpvsshW1Z_6LQCUGnwj1a9HPowauQmXqnlcAkmgfvbpBrt2xNumFtknwGBRR-lY47bkCYC6-Q76E7VJFasbWcGB4Tc6bd1dknC7-g4tZMKjiF1teO_LI" alt="Modern architecture">
            <div class="absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent"></div>
            <div class="absolute bottom-10 left-10 right-10">
              <div class="bg-surface-container-lowest/10 backdrop-blur-xl p-8 rounded-xl border border-white/20">
                <span class="material-symbols-outlined text-tertiary-fixed-dim text-4xl mb-4" style="font-variation-settings: 'FILL' 1;">format_quote</span>
                <p class="text-white text-lg italic mb-6">"DB Mainaly & Associates transformed our corporate governance structure, enabling our successful transition to a public entity."</p>
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-full bg-primary-fixed flex items-center justify-center font-bold text-primary">SC</div>
                  <div>
                    <p class="text-white font-bold text-sm">Sunil Chaudhary</p>
                    <p class="text-white/60 text-xs">CEO, Apex Infrastructure</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Latest Insights Section -->
    <section class="py-32 bg-surface">
      <div class="max-w-[1440px] mx-auto px-12">
        <div class="flex justify-between items-end mb-16">
          <div>
            <p class="text-primary font-bold tracking-[0.15em] uppercase text-xs mb-4">Financial Intelligence</p>
            <h2 class="text-4xl font-bold text-on-surface">Latest Insights</h2>
          </div>
          <a href="/blog" class="text-primary font-bold border-b-2 border-primary pb-1 hover:text-primary-container hover:border-primary-container transition-all">View All Publications</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          {featuredBlogPosts.map(post => (
            <article class="group">
              <div class="aspect-[16/10] bg-surface-container-high rounded-xl overflow-hidden mb-8">
                <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
              </div>
              <span class="text-primary text-[10px] font-bold tracking-widest uppercase mb-4 block">
                {post.data.category} • {post.data.date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
              </span>
              <h3 class="text-2xl font-bold mb-4 group-hover:text-primary transition-colors">
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
              </h3>
              <p class="text-on-surface-variant leading-relaxed mb-6 line-clamp-2">
                {post.data.excerpt}
              </p>
              <a href={`/blog/${post.id}`} class="material-symbols-outlined text-primary group-hover:translate-x-2 transition-transform">arrow_forward</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA Section -->
    <section class="bg-primary text-white py-24 mb-0">
      <div class="max-w-[1440px] mx-auto px-12 text-center">
        <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-8">Ready to secure your financial future?</h2>
        <p class="text-primary-fixed/70 text-xl max-w-2xl mx-auto mb-12">
          Schedule a confidential consultation with our principal partners to discuss your corporate advisory or audit requirements.
        </p>
        <div class="flex flex-wrap justify-center gap-6">
          <Button href="/contact" variant="secondary" size="lg">Contact Principal Partner</Button>
          <Button href="/about" variant="outline" size="lg">Request Firm Profile</Button>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
