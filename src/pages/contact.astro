---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';

const faqs = [
  {
    question: "What documents are required for initial tax consultation?",
    answer: "Typically, we require your previous three years of financial statements, current PAN/VAT registration certificates, and details of any outstanding tax liabilities or notices from the Inland Revenue Department."
  },
  {
    question: "Do you offer virtual consulting for international clients?",
    answer: "Yes, we provide secure digital consultation via Microsoft Teams and Zoom for international investors looking to navigate the Nepalese corporate landscape."
  },
  {
    question: "How do your fees structure work?",
    answer: "Our fees are structured based on the complexity and volume of work. We offer both project-based fixed pricing for audits and hourly rates for advisory services."
  },
  {
    question: "Are you a member of any international accounting networks?",
    answer: "We are a proud member of ICAN (The Institute of Chartered Accountants of Nepal) and maintain strong affiliations with global financial networks to ensure international compliance standards."
  }
];
---

<BaseLayout title="Contact Us | DB Mainaly & Associates">
  <Header />

  <main>
    <header class="relative overflow-hidden bg-primary-container py-24 md:py-32">
      <div class="absolute inset-0 bg-gradient-to-br from-primary to-primary-container opacity-90"></div>
      <div class="relative max-w-[1440px] mx-auto px-12 lg:pl-16 lg:pr-24">
        <div class="max-w-3xl">
          <span class="inline-block px-3 py-1 mb-6 text-xs font-bold tracking-[0.1rem] text-tertiary-fixed-dim bg-white/10 rounded uppercase">Get in Touch</span>
          <h1 class="text-5xl md:text-7xl font-extrabold text-white tracking-tight mb-8 leading-[1.1]">
            Let's secure your financial future together
          </h1>
          <p class="text-xl text-primary-fixed leading-relaxed max-w-2xl opacity-90">
            Expert financial advisory and corporate legal solutions tailored for Nepal's evolving economic landscape.
          </p>
        </div>
      </div>
    </header>

    <section class="max-w-[1440px] mx-auto px-12 lg:pl-16 lg:pr-24 py-20">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
        <div class="lg:col-span-7 bg-surface-container-lowest p-10 md:p-12 rounded-xl shadow-[0_20px_40px_rgba(0,35,111,0.04)]">
          <h2 class="text-3xl font-bold text-on-surface mb-2">Send us a Message</h2>
          <p class="text-on-surface-variant mb-10">Briefly outline your requirements and our partners will contact you within 24 business hours.</p>
          <form class="space-y-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-wider text-primary">Full Name</label>
                <input class="w-full bg-surface-container-low border-0 border-b border-transparent focus:ring-0 focus:border-primary focus:bg-surface-container-lowest transition-all py-4 px-0 placeholder:text-outline-variant" placeholder="John Doe" type="text"/>
              </div>
              <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-wider text-primary">Email Address</label>
                <input class="w-full bg-surface-container-low border-0 border-b border-transparent focus:ring-0 focus:border-primary focus:bg-surface-container-lowest transition-all py-4 px-0 placeholder:text-outline-variant" placeholder="john@company.com" type="email"/>
              </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-wider text-primary">Service Interest</label>
                <select class="w-full bg-surface-container-low border-0 border-b border-transparent focus:ring-0 focus:border-primary focus:bg-surface-container-lowest transition-all py-4 px-0 text-on-surface-variant">
                  <option>Tax Advisory</option>
                  <option>Audit & Assurance</option>
                  <option>Corporate Law</option>
                  <option>Financial Consulting</option>
                </select>
              </div>
              <div class="space-y-2">
                <label class="text-xs font-bold uppercase tracking-wider text-primary">Phone Number</label>
                <input class="w-full bg-surface-container-low border-0 border-b border-transparent focus:ring-0 focus:border-primary focus:bg-surface-container-lowest transition-all py-4 px-0 placeholder:text-outline-variant" placeholder="+977 1-XXXXXXX" type="tel"/>
              </div>
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold uppercase tracking-wider text-primary">How can we help?</label>
              <textarea class="w-full bg-surface-container-low border-0 border-b border-transparent focus:ring-0 focus:border-primary focus:bg-surface-container-lowest transition-all py-4 px-0 placeholder:text-outline-variant resize-none" placeholder="Describe your consultation needs..." rows="4"></textarea>
            </div>
            <Button type="submit" size="lg" class="w-full md:w-auto">Submit Inquiry</Button>
          </form>
        </div>

        <aside class="lg:col-span-5 space-y-12">
          <div class="bg-surface-container p-10 rounded-xl">
            <h3 class="text-xl font-bold text-on-surface mb-8 border-l-4 border-primary pl-4">Office Headquarters</h3>
            <div class="space-y-8">
              <div class="flex gap-4">
                <span class="material-symbols-outlined text-primary">location_on</span>
                <div>
                  <p class="font-bold text-on-surface">Physical Address</p>
                  <p class="text-on-surface-variant leading-relaxed">DB Mainaly & Associates Building<br/>Level 4, Corporate Plaza<br/>New Baneshwor, Kathmandu<br/>Nepal</p>
                </div>
              </div>
              <div class="flex gap-4">
                <span class="material-symbols-outlined text-primary">call</span>
                <div>
                  <p class="font-bold text-on-surface">Phone & Fax</p>
                  <p class="text-on-surface-variant">+977 1 4483012<br/>+977 9851000000</p>
                </div>
              </div>
              <div class="flex gap-4">
                <span class="material-symbols-outlined text-primary">mail</span>
                <div>
                  <p class="font-bold text-on-surface">Electronic Mail</p>
                  <p class="text-on-surface-variant">info@dbmainaly.com.np<br/>support@dbmainaly.com.np</p>
                </div>
              </div>
            </div>
          </div>
          <div class="relative w-full aspect-square rounded-xl overflow-hidden bg-surface-container-high group">
            <div class="absolute inset-0 flex flex-col items-center justify-center p-8 text-center bg-primary/5">
              <div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center mb-4 shadow-xl">
                <span class="material-symbols-outlined text-white text-3xl" style="font-variation-settings: 'FILL' 1;">pin_drop</span>
              </div>
              <h4 class="text-lg font-bold text-primary mb-2">We are here</h4>
              <p class="text-sm text-on-secondary-container">Centralized Hub, New Baneshwor</p>
            </div>
            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuD0sZsbfTajSAN2MeP6z8TkSSvB0Wti-_58SdbQm-_zk0KfI76qMLRzJmB8-KTyVjZj-8160EcXxcQ7vrJfaWrZzr8rEGMfPlm-WuiFY3hgX2oEA9Vg1Ci4Uf5Zsv9gGT_8WiQoT1EP1-t82OHSOnUVHRXPwZANIwUTQKrxqyDAWo3oK3j8VsUx3enjBcLnQDR5sABvjbdNpbpGXyFxAiyXv4Upr2ft8P_fgQLIjMe7lz1rxVljskrrGOYmpzAQ1QzYUtfVPX9Ohkg" alt="Map" class="absolute inset-0 w-full h-full object-cover mix-blend-overlay opacity-30 grayscale group-hover:grayscale-0 transition-all duration-500">
          </div>
        </aside>
      </div>
    </section>

    <section class="bg-surface-container-low py-24">
      <div class="max-w-[1440px] mx-auto px-12 lg:pl-16 lg:pr-24">
        <div class="max-w-4xl mx-auto">
          <h2 class="text-4xl font-extrabold text-on-surface text-center mb-16 tracking-tight">Frequently Asked Questions</h2>
          <div class="space-y-4">
            {faqs.map(faq => (
              <div class="bg-surface-container-lowest p-8 rounded-lg shadow-sm">
                <button class="flex justify-between items-center w-full text-left group">
                  <span class="text-lg font-bold text-on-surface group-hover:text-primary transition-colors">{faq.question}</span>
                  <span class="material-symbols-outlined text-primary">add</span>
                </button>
                <div class="mt-4 text-on-surface-variant leading-relaxed">
                  {faq.answer}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
