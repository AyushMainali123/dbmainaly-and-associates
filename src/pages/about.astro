---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

import H1 from '../components/typography/H1.astro';
import H2 from '../components/typography/H2.astro';
import H3 from '../components/typography/H3.astro';
import H4 from '../components/typography/H4.astro';
import P from '../components/typography/P.astro';
import Lead from '../components/typography/Lead.astro';
import Small from '../components/typography/Small.astro';

const leaders = [
  {
    name: "Dhruba B. Mainaly",
    role: "Senior Partner & Founder",
    description: "Fellow Chartered Accountant with 25 years of experience in statutory audits and strategic tax planning for multinational corporations.",
    image: "https://lh3.googleusercontent.com/aida-public/AB6AXuCp4-WD9FlZmnLW0j81NbrT0Kq-Z1a5yCEkbZlMxIPIQQDGDMRK7i1ziJuWlrHtzOwlk9UCswgn6qDqvN8VFHxJjbWxcFtc8ayk6j42BfxnlBsDogEUqC4S6Wrj0eq3luMLWCz-3AA8bvFDR1tPaLUR8kd5YjDx8Dt7RgazcTTC2nyAka3AHNeIwHLET3OL-Za-c1k_Cox5iq7og49QzMKyqE9iq37hXlGIjxxcx9v7Oy7SqYI1uekt-RI_h9zgTwTcUAw_IcSD58c",
    quote: "Precision is the cornerstone of sustainable enterprise."
  },
  {
    name: "Sunita K. Shrestha",
    role: "Partner - Tax Advisory",
    description: "Specializing in indirect taxation and compliance frameworks, ensuring institutional resilience in a volatile regulatory landscape.",
    image: "https://lh3.googleusercontent.com/aida-public/AB6AXuBBI_CIF7sVEp2e8Wrru1sJZtn3t59Lug-g12ZK9imdAf5WczKu-hW01G3Hc55jTC9ERg4NvJr4v_VKDCAYzs-a7AQJmWPpHoF9iaHP3YixpH1BrosmnnbhC0rs4I5GB0BvfajQJfqw7IaPCdq8bFTJf-zHADsVbIApd-hU2C3QNQ_Wv_bTHPRpAp_kNck80oV1VK3iQjbRjiz7I9nLxd-fJS3WA_ljFwHrjlYUnq_rxZ1svpA2jVSo9Ki3pPXAyBztfa8Nj3aGnjQ",
    quote: "Regulatory compliance is an opportunity for clarity."
  },
  {
    name: "Ramesh P. Adhikari",
    role: "Head of Corporate Law",
    description: "Advising on mergers, acquisitions, and restructuring with a focus on mitigating institutional risk and maximizing valuation.",
    image: "https://lh3.googleusercontent.com/aida-public/AB6AXuDmAsukcFXtsTJ6VgOwNX0cPojXvY1ysWIrh0Qzl1Zwn85ILg27MTuXtRc-LkYEGqvwhYRyNmyBf2kuFlVaQ9EoL-hkgDak10b48Np-0DQD_by5h7nskNtCnSNAk3EaT4IizfUryTPo-GC5hdRcUH9SJeIG2Xx_2JZTnMMwHQ5Lei3DXrxYXm_LJ3Y2px8yTwk4q3DdZF1DxhZchEXyQaWURZRrBR-oLA-xkikSHlPkuggiHmn3c5diYeihdADloJYxQWyVDsDKCek",
    quote: "Protecting corporate integrity through rigorous legal oversight."
  }
];
---

<BaseLayout title="About Us | DB Mainaly & Associates">
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="relative min-h-[500px] md:min-h-[716px] flex items-center overflow-hidden bg-primary py-20 md:py-0">
      <div class="absolute inset-0 opacity-20 pointer-events-none">
        <div class="absolute top-0 right-0 w-full md:w-1/2 h-full bg-gradient-to-bl from-primary-container to-transparent"></div>
        <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&q=80&w=2000" alt="Corporate board room" class="w-full h-full object-cover mix-blend-overlay">
      </div>
      <div class="relative max-w-[1440px] mx-auto px-6 md:px-12 w-full">
        <div class="max-w-3xl">
          <Small class="inline-block px-4 py-1.5 rounded-full bg-tertiary-fixed-dim text-on-tertiary-fixed tracking-widest uppercase mb-6 font-bold">ESTABLISHED AUTHORITY</Small>
          <H1 class="text-white mb-8">
            The Legacy of <br class="hidden md:block"/>Financial Stewardship
          </H1>
          <Lead class="text-primary-fixed mb-12 max-w-2xl font-light opacity-90">
            Guiding enterprises through the complexities of global finance with unwavering precision, local expertise, and a commitment to institutional excellence since our founding.
          </Lead>
          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <div class="h-[2px] w-12 bg-tertiary-fixed-dim hidden sm:block"></div>
            <Small class="text-primary-fixed font-semibold tracking-wide uppercase">A MEMBER OF THE INSTITUTE OF CHARTERED ACCOUNTANTS OF NEPAL</Small>
          </div>
        </div>
      </div>
    </section>

    <!-- Foundation of Purpose Section -->
    <section class="py-16 md:py-32 bg-surface relative overflow-hidden">
      <!-- Subtle Background Decorative Element -->
      <div class="absolute top-0 left-0 w-1/2 h-full bg-gradient-to-br from-primary/5 to-transparent pointer-events-none"></div>
      
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 grid grid-cols-1 lg:grid-cols-12 gap-12 md:gap-20 relative z-10">
        <!-- Left Column: Vision & Mission -->
        <div class="lg:col-span-12 xl:col-span-5 max-w-2xl lg:max-w-none">
          <div class="mb-12">
            <Small class="font-bold text-primary tracking-[0.2rem] uppercase mb-4 block animate-in fade-in slide-in-from-bottom-2 duration-700">Foundation of Purpose</Small>
            <H2 class="text-on-surface mb-6 leading-tight">Architecture of a Modern Advisory</H2>
            <div class="h-1.5 w-20 bg-primary/20 rounded-full mb-8">
              <div class="h-full w-1/2 bg-primary rounded-full"></div>
            </div>
            <P class="text-on-surface-variant text-lg leading-relaxed max-w-xl">
              Our firm is built upon three pillars that define every audit, advisory, and corporate strategy we execute. We do not just process numbers; we engineer trust.
            </P>
          </div>

          <div class="relative pl-16 md:pl-20 border-l-[0.175rem] border-primary/10 space-y-16 py-4">
            <!-- Timeline Item 1 -->
            <div class="relative group">
              <div class="absolute -left-[3.125rem] md:-left-[4.125rem] top-0 w-10 h-10 md:w-12 md:h-12 rounded-2xl bg-primary shadow-[0_8px_16px_rgba(0,35,111,0.2)] flex items-center justify-center text-white transition-all duration-300">
                <span class="material-symbols-outlined text-lg md:text-xl">visibility</span>
              </div>
              <div class="transition-transform duration-300 group-hover:translate-x-2">
                <H4 class="text-primary mb-3 font-bold flex items-center gap-3">
                  Our Vision
                  <span class="h-px flex-1 bg-primary/10 hidden md:block"></span>
                </H4>
                <P class="text-on-surface-variant mb-0 text-lg">To be the most trusted financial vanguard in the region, bridging Nepalese enterprise with global standards.</P>
              </div>
            </div>

            <!-- Timeline Item 2 -->
            <div class="relative group">
              <div class="absolute -left-[3.125rem] md:-left-[4.125rem] top-0 w-10 h-10 md:w-12 md:h-12 rounded-2xl bg-surface-container-high border-2 border-primary/30 flex items-center justify-center text-primary transition-all duration-300">
                <span class="material-symbols-outlined text-lg md:text-xl">rocket_launch</span>
              </div>
              <div class="transition-transform duration-300 group-hover:translate-x-2">
                <H4 class="text-primary mb-3 font-bold flex items-center gap-3">
                  Our Mission
                  <span class="h-px flex-1 bg-primary/10 hidden md:block"></span>
                </H4>
                <P class="text-on-surface-variant mb-0 text-lg">Delivering uncompromising integrity and analytical depth to empower sustainable corporate growth.</P>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Column: Values Cards -->
        <div class="lg:col-span-12 xl:col-span-7 grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
          <div class="group bg-surface-container-lowest p-8 md:p-12 rounded-2xl shadow-[0_4px_20px_rgba(0,0,0,0.03)] border border-outline-variant/10 hover:border-primary/20 hover:shadow-[0_20px_50px_rgba(0,35,111,0.08)] transition-all duration-500 hover:-translate-y-2">
            <div class="w-16 h-16 bg-primary/5 rounded-xl flex items-center justify-center mb-8 transition-colors group-hover:bg-primary/10">
              <span class="material-symbols-outlined text-primary text-4xl">gavel</span>
            </div>
            <H4 class="text-on-surface mb-6 font-bold">Integrity</H4>
            <P class="text-on-surface-variant leading-relaxed mb-0">Absolute transparency in all professional engagements, ensuring compliance with the highest ethical mandates.</P>
          </div>

          <div class="group bg-surface-container-lowest p-8 md:p-12 rounded-2xl shadow-[0_4px_20px_rgba(0,0,0,0.03)] border border-outline-variant/10 hover:border-primary/20 hover:shadow-[0_20px_50px_rgba(0,35,111,0.08)] transition-all duration-500 hover:-translate-y-2 md:mt-12">
            <div class="w-16 h-16 bg-primary/5 rounded-xl flex items-center justify-center mb-8 transition-colors group-hover:bg-primary/10">
              <span class="material-symbols-outlined text-primary text-4xl">precision_manufacturing</span>
            </div>
            <H4 class="text-on-surface mb-6 font-bold">Precision</H4>
            <P class="text-on-surface-variant leading-relaxed mb-0">Eliminating ambiguity through rigorous data analysis and methodical cross-verification protocols.</P>
          </div>

          <div class="bg-primary text-white p-10 md:p-14 rounded-3xl md:col-span-2 relative overflow-hidden group shadow-2xl shadow-primary/20">
            <!-- Decorative circle -->
            <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -mr-32 -mt-32 transition-transform duration-1000 group-hover:scale-150"></div>
            
            <div class="relative z-10 flex flex-col md:flex-row items-center gap-10">
              <div class="flex-shrink-0">
                <div class="w-24 h-24 bg-white/10 rounded-2xl backdrop-blur-sm flex items-center justify-center border border-white/20 transition-all duration-500 group-hover:rotate-12">
                  <span class="material-symbols-outlined text-white text-6xl">hub</span>
                </div>
              </div>
              <div>
                <H3 class="text-white mb-6">Client Stewardship</H3>
                <P class="text-blue-50 leading-relaxed mb-0 text-lg opacity-90 font-light">
                  Our relationships are viewed as decades-long partnerships, prioritizing the long-term stability of the institutions we serve over short-term metrics.
                </P>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Leadership Section -->
    <section class="py-16 md:py-32 bg-surface-container-low">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 md:mb-20 gap-8">
          <div class="max-w-2xl">
            <Small class="font-bold text-primary tracking-[0.1rem] uppercase mb-4 block">Executive Leadership</Small>
            <H2 class="text-on-surface">Managed by Experts, <br class="hidden md:block"/>Driven by Excellence.</H2>
          </div>
          <P class="text-on-surface-variant text-lg max-w-sm mb-0">Our partners bring over 60 years of combined experience across auditing, taxation, and law.</P>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12">
          {leaders.map(leader => (
            <div class="group">
              <div class="relative overflow-hidden rounded-xl mb-6 md:mb-8 aspect-[3/4] bg-surface-container-high">
                <img src={leader.image} alt={leader.name} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
                <div class="absolute inset-0 bg-gradient-to-t from-primary/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6 md:p-8">
                  <p class="text-white text-sm italic">"{leader.quote}"</p>
                </div>
              </div>
              <H4 class="text-on-surface mb-1">{leader.name}</H4>
              <Small class="text-primary font-bold tracking-widest uppercase mb-4 block">{leader.role}</Small>
              <P class="text-on-surface-variant leading-relaxed">{leader.description}</P>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Professional Accreditations Section -->
    <section class="py-16 md:py-24 bg-surface-container-lowest border-y border-outline-variant/15">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12 text-center">
        <Small class="font-bold text-primary tracking-[0.2rem] uppercase mb-4 block">Institutional Recognition</Small>
        <div class="h-1 w-20 bg-tertiary-fixed-dim mx-auto mb-16 rounded-full"></div>
        <div class="grid grid-cols-2 md:grid-cols-4 items-center gap-12 opacity-80 grayscale hover:grayscale-0 transition-all duration-500">
          <div class="flex flex-col items-center">
            <div class="w-20 h-20 md:w-24 md:h-24 bg-surface-container rounded-full flex items-center justify-center mb-4 text-primary font-black text-xl md:text-2xl">ICAN</div>
            <p class="text-on-surface font-bold text-sm">IC Nepal Member</p>
          </div>
          <div class="flex flex-col items-center">
            <div class="w-20 h-20 md:w-24 md:h-24 bg-surface-container rounded-full flex items-center justify-center mb-4 text-primary font-black text-xl md:text-2xl">IFAC</div>
            <p class="text-on-surface font-bold text-sm">IFAC Compliance</p>
          </div>
          <div class="flex flex-col items-center">
            <div class="w-20 h-20 md:w-24 md:h-24 bg-surface-container rounded-full flex items-center justify-center mb-4">
              <span class="material-symbols-outlined text-primary text-3xl md:text-4xl">verified_user</span>
            </div>
            <p class="text-on-surface font-bold text-sm">ISO 9001 Certified</p>
          </div>
          <div class="flex flex-col items-center">
            <div class="w-20 h-20 md:w-24 md:h-24 bg-surface-container rounded-full flex items-center justify-center mb-4">
              <span class="material-symbols-outlined text-primary text-3xl md:text-4xl">language</span>
            </div>
            <p class="text-on-surface font-bold text-sm">Global Standards</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
